.MODEL SMALL
.STACK 100H
.DATA   



MSG1 DB 10,13,'ENTER A NUMBER:$'
MSG2 DB 10,13,'THIS IS AN EVEN NUMBER$'
MSG3 DB 10,13,'THIS IS AN ODD NUMBER$'
DISPLAY MACRO MSG ;DEFINING MACRO
 MOV AH,9
 LEA DX,MSG
 INT 21H
ENDM ;END OF MACRO
                   
                   

MSG4 DB 10,13,10,13,'MD. MORSALIN KHAN NOYON$'
MSG5 DB 10,13,'ROLL: 2208$'
NEWLINE DB 10,13,'$'


.CODE




MAIN PROC
 MOV AX,@DATA
 MOV DS,AX
 DISPLAY MSG1 ;CALL MACRO
 MOV AH,1
 INT 21H
 MOV AH,0
 MOV DL,2
 DIV DL
 CMP AH,0
 JNE ODD
 EVEN:
 DISPLAY MSG2
 JMP DONE
 ODD:
 DISPLAY MSG3
 DONE:
 MOV AH,4CH


 MOV AX, @DATA   
    MOV DS, AX
    LEA DX, MSG4
    MOV AH, 09H
    INT 21H  
     LEA DX, MSG5
    MOV AH, 09H
    INT 21H
 MAIN ENDP
ENDP MAIN
