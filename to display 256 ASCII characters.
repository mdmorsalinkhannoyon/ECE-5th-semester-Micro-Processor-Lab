.MODEL SMALL
.STACK 100H
.DATA   

PROMPT  DB  'The 256 ASCII Characters are : $\'                
                   

MSG4 DB 10,13,10,13,'MD. MORSALIN KHAN NOYON$'
MSG5 DB 10,13,'ROLL: 2208$'
NEWLINE DB 10,13,'$'


.CODE
 MAIN PROC 
      
  
 MOV AX, @DATA ;INITIALIZE DS
 MOV DS, AX
 LEA DX, PROMPT ;LOAD AND PRINT PROMPT
 MOV AH, 9
 INT 21H
 MOV CX, 256 ;INITIALIZE CX
 MOV AH, 2 ;SET OUTPUT FUNCTION
 MOV DL, 0 ;INITIALIZE DL WITH FIRST ASCII CHARACTER
 @LOOP: ;LOOP LABEL
 INT 21H ;PRINT ASCII CHARACTER
 INC DL ;INCREMENT DL TO NEXT ASCII CHARACTER
 DEC CX ;DECREMENT CX
 JNZ @LOOP ;JUMP TO LABEL @LOOP IF CX IS 0


          MOV AX, @DATA   
    MOV DS, AX
    LEA DX, MSG4
    MOV AH, 09H
    INT 21H  
     LEA DX, MSG5
    MOV AH, 09H
    INT 21H 
    
   MOV AH, 4CH ;RETURN CONTROL TO DOS
 INT 21H

   
     MAIN ENDP
ENDP MAIN
